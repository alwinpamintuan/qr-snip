{
  "name": "qr-snip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scan a QR code anywhere in the visible browser tab with a privacy-first snipping tool.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "build:all": "pnpm build && pnpm build:firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm test && pnpm build:all",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wxt": "^0.20.11"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
