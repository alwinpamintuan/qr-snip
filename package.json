{
  "name": "qr-snip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scan a QR code anywhere in the visible browser tab with a privacy-first snipping tool.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alwinpamintuan/qr-snip.git"
  },
  "bugs": {
    "url": "https://github.com/alwinpamintuan/qr-snip/issues"
  },
  "homepage": "https://github.com/alwinpamintuan/qr-snip#readme",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "build:all": "pnpm build && pnpm build:firefox",
    "permissions:check": "node scripts/assert-manifest.mjs",
    "locales:check": "node scripts/assert-locales.mjs",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:prepare": "vite build --config e2e/vite.config.ts",
    "e2e:firefox:lint": "web-ext lint --source-dir .output/firefox-mv3",
    "test:e2e:browser": "playwright test",
    "test:e2e": "pnpm build:all && pnpm permissions:check && pnpm e2e:prepare && pnpm e2e:firefox:lint && pnpm test:e2e:browser",
    "test:e2e:stability": "pnpm e2e:prepare && playwright test --project=chromium-harness --project=firefox-harness --grep \"@critical\" --repeat-each=100 --workers=4 --retries=1",
    "fixtures:generate": "node scripts/generate-qr-fixtures.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm locales:check && pnpm build:all && pnpm permissions:check && pnpm e2e:prepare && pnpm e2e:firefox:lint && pnpm test:e2e:browser",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "punycode": "^2.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/punycode": "^2.1.4",
    "@types/qrcode": "^1.5.6",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "web-ext": "^10.5.0",
    "wxt": "^0.20.11"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
